#!/usr/bin/env python3

__author__ = "furcelay"

from legacy_to_rcs2.pipeline import query_and_write
from tqdm import tqdm
from multiprocessing import Pool, BoundedSemaphore, Lock
from argparse import ArgumentParser
from astropy.table import Table
import os
import sys
import datetime


def parse_args():
    parser = ArgumentParser()
    parser.add_argument("input_table", type=str,
                        help="Input astropy table .fits file")
    parser.add_argument("--output_dir", '-o', type=str, default=None,
                        help="Output directory")
    parser.add_argument("--hsc_release", type=str, default="pdr3_dud_rev",
                        choices=["pdr3_dud_rev", "pdr3_dud", "pdr3_wide",
                                 "pdr2_dud", "pdr2_wide",
                                 "pdr1_udeep", "pdr1_deep", "pdr1_wide", "pdr1_ssp_uh_cosmos"],
                        help="HSC release to use, note that this defines the depth (wide or deep)")
    parser.add_argument("--num_processes", '-np', type=int, default=10,
                        help="Number of processes to use")
    parser.add_argument("--num_connections", '-nc', type=int, default=8,
                        help="Number of connections to use for the HSC query")
    parser.add_argument("--timeout", '-t', type=int, default=60,
                        help="Timeout for the HSC query")
    parser.add_argument("--hsc_username", type=str, default=None,
                        help="HSC username, otherwise use env variable HSC_SSP_CAS_USERNAME")
    parser.add_argument("--hsc_password", type=str, default=None,
                        help="HSC password, otherwise use env variable HSC_SSP_CAS_PASSWORD")
    parser.add_argument("--restart", "-r", action="store_true",
                        help="Restart the query from the last successful query")
    parser.add_argument("--retry", "-rr", action="store_true",
                        help="Restart and retry failed queries")
    return parser.parse_args()


timestamp = datetime.datetime.now().strftime('%Y%m%d%H%M%S')
args = parse_args()
catalog = Table.read(args.input_table)

out_dir = args.output_dir
if out_dir is None:
    out_dir = os.path.splitext(args.input_table)[0] + "_query"

os.makedirs(out_dir, exist_ok=True)

if args.retry:
    queried = os.listdir(out_dir)
    queried_success = [(f"{i:06d}_img_z.fits" in queried) for i in range(len(catalog))]
    run_list = [i for i in range(len(catalog)) if not queried_success[i]]
elif args.restart:
    queried = sorted(os.listdir(out_dir))
    if queried:
        start_id = int([d for d in queried if "z" in d][-1].replace("_z.fits", "")) + 1
    else:
        start_id = 0
    run_list = range(start_id, len(catalog))
else:
    if os.listdir(out_dir):
        print("Output directory is not empty, please use --retry or --restart or empty the directory")
        sys.exit(1)
    if os.path.exists(f"{out_dir}_out.log"):
        os.remove(f"{out_dir}_out.log")
    if os.path.exists(f"{out_dir}_err.log"):
        os.remove(f"{out_dir}_err.log")
    run_list = range(len(catalog))

if not os.path.exists(f"{out_dir}_out_{timestamp}.log"):
    with open(f"{out_dir}_out.log", "w") as f:
        f.write(f"{'ID':6s}\t{'Success':5s}\n")


def process_row(idx):
    row = catalog[idx]
    ra, dec = row['ra'], row['dec']
    out_filename = os.path.join(out_dir, f"{idx:06d}")
    succeed = query_and_write(
        out_filename,
        ra,
        dec,
        semaphore,
        username=args.hsc_username,
        password=args.hsc_password,
        query_timeuot=60,
        hsc_size_arcsec=20,
        field=args.hsc_release,
        bands='grizy',
        log_file=f"{out_dir}_err.log",
        log_lock=log_lock,
        log_prefix=f"{idx:06d}: ",
        require_psf=True,
    )
    return idx, succeed


def init_child(semaphore_, log_lock_):
    global semaphore
    semaphore = semaphore_
    global log_lock
    log_lock = log_lock_


if __name__ == "__main__":
    semaphore = BoundedSemaphore(args.num_connections)
    log_lock = Lock()

    with Pool(args.num_processes, initializer=init_child, initargs=(semaphore, log_lock)) as pool:
        for (i, success) in tqdm(pool.imap(process_row, run_list), total=len(run_list)):
            with open(f"{out_dir}_out_{timestamp}.log", "a") as f:
                f.write(f"{i:06d}\t{str(success):5s}\n")

    queried = os.listdir(out_dir)
    success_list = [(f"{i:06d}_img_z.fits" in queried) for i in range(len(catalog))]
    num_completed = sum(success_list)
    num_failed = len(success_list) - sum(success_list)
    print(f"All done, completed: {num_completed}, failed: {num_failed}")
