#!/usr/bin/env python3

__author__ = "furcelay"

from legacy_to_rcs2.pipeline import read_degrade_write
from legacy_to_rcs2.lsst_props import dp0_gmm_sampler
from tqdm import tqdm
from multiprocessing import Pool, Lock
from argparse import ArgumentParser
import os
import sys
import datetime


def parse_args():
    parser = ArgumentParser()
    parser.add_argument("input_directory", type=str,
                        help="Input directory")
    parser.add_argument("--output_dir", '-o', type=str, default=None,
                        help="Output directory")
    parser.add_argument("--coadd_years", '-y', type=str, default="1",
                        help="Years of coadd to use, can be a number or 'single_visit'")
    parser.add_argument("--hsc_release", type=str, default="pdr3_dud_rev",
                        choices=["pdr3_dud_rev", "pdr3_dud", "pdr3_wide",
                                 "pdr2_dud", "pdr2_wide",
                                 "pdr1_udeep", "pdr1_deep", "pdr1_wide", "pdr1_ssp_uh_cosmos"],
                        help="HSC depth to use, can be 'wide' or 'deep'")
    parser.add_argument("--num_processes", '-np', type=int, default=10,
                        help="Number of processes to use")
    parser.add_argument("--rms_frac_thresh", type=float, default=0.3,
                        help="Threshold for the RMS_HSC/RMS_LSST for the zero point conversion")
    parser.add_argument("--max_mag_change", type=float, default=0.5,
                        help="Maximum magnitude variation allowed during the zero point conversion")
    parser.add_argument("--restart", "-r", action="store_true",
                        help="Restart the query from the last successful query")
    parser.add_argument("--retry", "-rr", action="store_true",
                        help="Restart and retry failed queries")
    return parser.parse_args()


timestamp = datetime.datetime.now().strftime('%Y%m%d%H%M%S')
args = parse_args()
input_files = os.listdir(args.input_directory)
input_ids = sorted(list(set([f.split("_")[0] for f in input_files])))

out_dir = args.output_dir
if out_dir is None:
    out_dir = args.input_directory + "_degraded"
dp0_sampler = dp0_gmm_sampler(args.coadd_years)


os.makedirs(out_dir, exist_ok=True)

if args.retry:
    degraded = os.listdir(out_dir)
    degraded_success = [(f"{idx}_z.fits" in degraded) for idx in input_ids]
    run_list = [idx for i, idx in enumerate(input_ids) if not degraded_success[i]]
elif args.restart:
    degraded = sorted(os.listdir(out_dir))
    if degraded:
        last_idx = [d for d in degraded if "z" in d][-1].replace("_img_z.fits", "")
        start_id = input_ids.index(last_idx) + 1
    else:
        start_id = 0
    run_list = input_ids[start_id:]
else:
    if os.listdir(out_dir):
        print("Output directory is not empty, please use --retry or --restart or empty the directory")
        sys.exit(1)
    if os.path.exists(f"{out_dir}_out.log"):
        os.remove(f"{out_dir}_out.log")
    if os.path.exists(f"{out_dir}_err.log"):
        os.remove(f"{out_dir}_err.log")
    run_list = input_ids

if not os.path.exists(f"{out_dir}_out_{timestamp}.log"):
    with open(f"{out_dir}_out.log", "w") as f:
        f.write(f"{'ID':6s}\t{'success':5s}\tmag_change\n")


def process_row(idx):
    in_filename = os.path.join(args.input_directory, idx)
    out_filename = os.path.join(out_dir, idx)
    succeed_, mag_change_ = read_degrade_write(
        in_filename,
        out_filename,
        dp0_sampler,
        zp_rms_frac_thresh=args.rms_frac_thresh,
        zp_max_mag_change=args.max_mag_change,
        lsst_size_pix=41,
        bands='grizy',
        log_file=f"{out_dir}_err.log",
        log_lock=log_lock,
        log_prefix=f"{idx}: ",
    )
    return idx, succeed_, mag_change_


def init_child(log_lock_):
    global log_lock
    log_lock = log_lock_


if __name__ == "__main__":
    log_lock = Lock()

    with Pool(args.num_processes, initializer=init_child, initargs=(log_lock,)) as pool:
        for (idx, success, mag_change) in tqdm(pool.imap(process_row, run_list), total=len(run_list)):
            with open(f"{out_dir}_{timestamp}_out.log", "a") as f:
                f.write(f"{idx}\t{str(success):5s}\t{mag_change:.3f}\n")

    degraded = os.listdir(out_dir)
    success_list = [(f"{idx}_z.fits" in degraded) for idx in input_ids]
    num_completed = sum(success_list)
    num_failed = len(success_list) - sum(success_list)
    print(f"All done, completed: {num_completed}, failed: {num_failed}")
